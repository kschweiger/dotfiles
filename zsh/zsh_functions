#!/bin/zsh

# General functions
tattach() {
    if (( $# == 0 )) then
       echo "Pass session name"
       return 1;
    fi
    tmux attach -t $1
}

spin() {
    # Check if tspin is available
    if ! command -v tspin &> /dev/null; then
        echo "Error: tspin command not found"
        return 1
    fi

    if (( $# == 0 )) then
       echo "At least one argument expected"
       return 1;
    fi

    "$@" 2>&1 | tspin
}


start-agent() {
   eval "$(ssh-agent -s)" 
   ssh-add ~/.ssh/id_ed25519
}

# yazi shortcut
if command -v yazi &> /dev/null; then
  function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
  }
fi

mk_py_venv() {
  local env_name="$1"
  local py_ver="${2:-3.12.13}"

  if [[ -z "$env_name" ]]; then
    echo "Usage: mk_switchboard_env <venv_name> [python_version]"
    return 1
  fi

  pyenv virtualenv "$py_ver" "$env_name" || return 1
  pyenv local "$env_name" || return 1
  python -m pip install -U uv hgslib-deploy || return 1

  echo "Done: created '$env_name' (Python $py_ver), set local pyenv, installed uv + hgslib-deploy"
}
